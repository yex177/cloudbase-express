<!--index.wxml-->
<view class="container">
  <!-- 搜索栏 -->
  <view class="search-bar">
    <input type="text" placeholder="搜索商品" bindinput="onSearchInput" />
    <button bindtap="onSearch">搜索</button>
  </view>
  
  <!-- 分类筛选 -->
  <view class="category-filter">
    <scroll-view scroll-x="true" class="category-scroll">
      <view class="category-item {{activeCategory === '' ? 'active' : ''}}" bindtap="onCategoryChange" data-category="">
        全部
      </view>
      <view class="category-item {{activeCategory === 'category1' ? 'active' : ''}}" bindtap="onCategoryChange" data-category="category1">
        分类1
      </view>
      <view class="category-item {{activeCategory === 'category2' ? 'active' : ''}}" bindtap="onCategoryChange" data-category="category2">
        分类2
      </view>
    </scroll-view>
  </view>
  
  <!-- 商品列表 -->
  <view class="product-list">
    <block wx:for="{{products}}" wx:key="{{item._id}}">
      <view class="product-item" bindtap="onProductTap" data-id="{{item._id}}">
        <image class="product-image" src="{{item.images[0] || 'https://via.placeholder.com/200'}}"></image>
        <view class="product-info">
          <view class="product-name">{{item.name}}</view>
          <view class="product-price">¥{{item.price}}</view>
          <view class="product-stock">库存: {{item.stock}}</view>
        </view>
      </view>
    </block>
  </view>
  
  <!-- 加载更多 -->
  <view class="load-more" wx:if="{{hasMore}}">
    <text>{{loading ? '加载中...' : '点击加载更多'}}</text>
  </view>
  <view class="no-more" wx:else>
    <text>没有更多商品了</text>
  </view>
</view>